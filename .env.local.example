NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:1338
# Remote CMS (requires Users-Permissions JWT)
# NEXT_PUBLIC_API_BASE_URL=http://165.227.235.2:1337
NEXT_PUBLIC_AUTH_BASE_URL=http://127.0.0.1:1338
NEXT_PUBLIC_API_TOKEN=replace-with-users-permissions-jwt
# Optional helper for dev instances where JWT isn't wired yet
NEXT_PUBLIC_DEV_CUSTOMER_ID=
NEXT_PUBLIC_ANALYTICS_KEY=local-analytics-key
# Optional locker / invoice integrations
NEXT_PUBLIC_LOCKER_API_URL=
NEXT_PUBLIC_LOCKER_API_TOKEN=
# Remote health check: curl http://165.227.235.2:1337/_health should return 204
# When pointing to remote CMS use e.g. http://cms.greenhub420.co.uk:1337
